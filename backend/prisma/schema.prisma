// Prisma Schema — VoiceForge AI
// Self-hosted Voice AI Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// VOICE AGENTS - Configurable AI personas
// ============================================
model Agent {
  id              String   @id @default(uuid())
  name            String
  systemPrompt    String   @default("You are a helpful voice assistant. Be concise and natural.")
  greeting        String   @default("Hello! How can I help you today?")
  voice           String   @default("af_heart")
  language        String   @default("en")
  llmModel        String   @default("llama3.2")
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(150)
  interruptible   Boolean  @default(true)
  silenceTimeout  Int      @default(1500)  // ms before considering turn complete
  endCallPhrases  String   @default("goodbye,bye,end call,hang up")  // comma-separated
  
  // Retail / Business features
  transferNumber  String?  // Number to transfer to if needed
  knowledgeBase   String?  // JSON string of FAQ/knowledge items
  webhookUrl      String?  // Webhook to call on events
  webhookEvents   String   @default("call.started,call.ended,transcript.complete")
  
  // Metadata
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  calls           Call[]
  phoneNumbers    PhoneNumber[]
}

// ============================================
// CALLS - Every voice interaction tracked
// ============================================
model Call {
  id              String   @id @default(uuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Call metadata
  direction       String   @default("inbound")  // inbound | outbound | browser
  status          String   @default("ringing")    // ringing | active | ended | failed
  callerNumber    String?
  calledNumber    String?
  
  // Twilio
  twilioCallSid   String?  @unique
  twilioStreamSid String?
  
  // Timing
  startedAt       DateTime @default(now())
  answeredAt      DateTime?
  endedAt         DateTime?
  durationMs      Int      @default(0)
  
  // AI Metrics
  totalTokens     Int      @default(0)
  sttLatencyMs    Int      @default(0)   // Average STT latency
  llmLatencyMs    Int      @default(0)   // Average LLM latency  
  ttsLatencyMs    Int      @default(0)   // Average TTS latency
  totalLatencyMs  Int      @default(0)   // Average total pipeline latency
  
  // Cost tracking (should be $0 for self-hosted)
  costUsd         Float    @default(0)
  
  // Relations
  messages        Message[]
  
  @@index([agentId])
  @@index([status])
  @@index([startedAt])
}

// ============================================
// MESSAGES - Full conversation transcript
// ============================================
model Message {
  id          String   @id @default(uuid())
  callId      String
  call        Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  
  role        String   // user | assistant | system
  content     String
  
  // Latency breakdown
  sttMs       Int      @default(0)
  llmMs       Int      @default(0)
  ttsMs       Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([callId])
}

// ============================================
// PHONE NUMBERS - Twilio number <-> Agent mapping
// ============================================
model PhoneNumber {
  id          String   @id @default(uuid())
  number      String   @unique
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  label       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  @@index([agentId])
}

// ============================================
// KNOWLEDGE BASE - RAG-lite document storage
// ============================================
model KnowledgeItem {
  id          String   @id @default(uuid())
  agentId     String
  category    String   @default("general")
  question    String
  answer      String
  keywords    String   @default("")  // comma-separated for fast search
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([agentId])
  @@index([category])
}

// ============================================
// SYSTEM SETTINGS
// ============================================
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
