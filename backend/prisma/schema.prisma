// Prisma Schema for OpenCalendar
// Multi-tenant Unified Calendar Synchronization Engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  displayName   String?
  passwordHash  String?    // For local auth (optional - can use OAuth-only)
  avatarUrl     String?
  timezone      String     @default("UTC")
  
  // SaaS & Admin
  isAdmin           Boolean          @default(false)
  plan              Plan             @default(FREE_TRIAL)
  subscriptionStatus String           @default("ACTIVE")
  stripeCustomerId  String?
  
  // Preferences
  conflictStrategy  ConflictStrategy @default(BLOCK_ALL)
  autoSyncEnabled   Boolean          @default(true)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  identities        Identity[]
  calendarEvents    CalendarEvent[]
  shadowBlocks      ShadowBlock[]
  syncLogs          SyncLog[]
  webhookSubs       WebhookSubscription[]
  availabilitySlots AvailabilitySlot[]

  @@map("users")
}

enum Plan {
  FREE_TRIAL
  PRO
  ENTERPRISE
}

enum ConflictStrategy {
  BLOCK_ALL        // Block on all providers when busy on any
  PRIORITY_BASED   // User-defined provider priority
  MANUAL_RESOLVE   // Notify user for manual resolution
}

// ============================================
// CALENDAR IDENTITIES (Connected Accounts)
// ============================================

model Identity {
  id               String       @id @default(uuid())
  userId           String
  providerType     ProviderType
  providerEmail    String       // email associated with this provider
  providerAccountId String?     // External ID from provider
  
  // Encrypted OAuth Tokens (AES-256-GCM)
  accessTokenEnc   String       @db.Text
  refreshTokenEnc  String?      @db.Text
  tokenExpiresAt   DateTime?
  tokenIv          String       // Initialization vector for AES
  
  // Sync State
  latestSyncToken  String?      @db.Text  // Google syncToken / MS deltaLink
  lastSyncedAt     DateTime?
  isActive         Boolean      @default(true)
  isPrimary        Boolean      @default(false)
  
  // Calendar-specific
  calendarId       String?      // Google calendarId or Outlook calendar ID
  calendarName     String?
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvents   CalendarEvent[]
  shadowBlocks     ShadowBlock[]
  syncLogs         SyncLog[]
  webhookSubs      WebhookSubscription[]

  @@unique([userId, providerType, providerEmail])
  @@map("identities")
}

enum ProviderType {
  GOOGLE_PERSONAL   // @gmail.com
  GOOGLE_WORKSPACE  // @company.com (Google Workspace)
  MICROSOFT_PERSONAL // @outlook.com, @hotmail.com
  MICROSOFT_365     // @enterprise.com (M365 Business)
}

// ============================================
// CALENDAR EVENTS (Canonical Events)
// ============================================

model CalendarEvent {
  id                String       @id @default(uuid())
  userId            String
  identityId        String
  
  // Provider-side identifiers
  externalEventId   String       // Event ID from Google/Microsoft
  externalCalendarId String?
  
  // Event Data
  title             String
  description       String?
  location          String?
  startTime         DateTime
  endTime           DateTime
  isAllDay          Boolean      @default(false)
  status            EventStatus  @default(CONFIRMED)
  busyStatus        BusyStatus   @default(BUSY)
  
  // Sync Metadata
  syncOrigin        String?      // "calendarsync-ai-system" for system-generated
  isSystemGenerated Boolean      @default(false)
  etag              String?      // For change detection
  rawPayload        Json?        // Original provider payload
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity          Identity     @relation(fields: [identityId], references: [id], onDelete: Cascade)
  shadowBlocks      ShadowBlock[] @relation("SourceEvent")

  @@unique([identityId, externalEventId])
  @@index([userId, startTime, endTime])
  @@index([syncOrigin])
  @@map("calendar_events")
}

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}

enum BusyStatus {
  BUSY
  FREE
  TENTATIVE
  OUT_OF_OFFICE
  WORKING_ELSEWHERE
}

// ============================================
// SHADOW BLOCKS (System-Generated Blockers)
// ============================================

model ShadowBlock {
  id                String       @id @default(uuid())
  userId            String
  
  // Source: The original event that triggered this block
  sourceEventId     String
  sourceIdentityId  String
  
  // Target: Where the block was created
  targetIdentityId  String
  targetExternalId  String?      // The event ID created in the target provider
  
  // Block Details
  title             String       @default("Reserved (CalendarSync)")
  startTime         DateTime
  endTime           DateTime
  status            ShadowStatus @default(ACTIVE)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEvent       CalendarEvent @relation("SourceEvent", fields: [sourceEventId], references: [id], onDelete: Cascade)
  sourceIdentity    Identity     @relation(fields: [sourceIdentityId], references: [id], onDelete: Cascade)

  @@unique([sourceEventId, targetIdentityId])
  @@index([userId, startTime, endTime])
  @@map("shadow_blocks")
}

enum ShadowStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  ERROR
}

// ============================================
// SYNC LOG (Audit Trail)
// ============================================

model SyncLog {
  id              String       @id @default(uuid())
  userId          String
  identityId      String?
  
  action          SyncAction
  status          SyncStatus   @default(PENDING)
  
  // Event references
  sourceEventId   String?
  targetEventId   String?
  externalEventId String?
  
  // Details
  providerType    ProviderType?
  direction       SyncDirection?
  metadata        Json?        // Additional context
  errorMessage    String?
  
  startedAt       DateTime     @default(now())
  completedAt     DateTime?

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity        Identity?    @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([externalEventId])
  @@map("sync_logs")
}

enum SyncAction {
  WEBHOOK_RECEIVED
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  SHADOW_CREATED
  SHADOW_DELETED
  CONFLICT_DETECTED
  CONFLICT_RESOLVED
  TOKEN_REFRESHED
  FULL_SYNC
  LOOP_PREVENTED
}

enum SyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED
}

enum SyncDirection {
  GOOGLE_TO_MICROSOFT
  MICROSOFT_TO_GOOGLE
  GOOGLE_TO_GOOGLE
  MICROSOFT_TO_MICROSOFT
  INBOUND
  OUTBOUND
}

// ============================================
// WEBHOOK SUBSCRIPTIONS
// ============================================

model WebhookSubscription {
  id              String       @id @default(uuid())
  userId          String
  identityId      String
  
  providerType    ProviderType
  subscriptionId  String       // Channel ID (Google) or Subscription ID (Microsoft)
  resourceId      String?      // Google resource ID
  
  expiresAt       DateTime
  isActive        Boolean      @default(true)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity        Identity     @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId])
  @@index([expiresAt])
  @@map("webhook_subscriptions")
}

// ============================================
// GLOBAL AVAILABILITY SLOTS (Computed View)
// ============================================

model AvailabilitySlot {
  id          String       @id @default(uuid())
  userId      String
  
  startTime   DateTime
  endTime     DateTime
  status      BusyStatus   @default(BUSY)
  
  // Source tracking
  sourceProvider  ProviderType?
  sourceEventId   String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime, endTime])
  @@map("availability_slots")
}
