# ============================================
# VoiceForge AI - Environment Configuration
# Zero-cost self-hosted Voice AI Platform
# ============================================

# Server
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# LOCAL AI SERVICES (all free, self-hosted)
# ============================================

# Ollama - Local LLM (free, unlimited)
# Install: https://ollama.ai
# Models: ollama pull llama3.2, mistral, phi3, gemma2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_KEEP_ALIVE=-1

# Kokoro TTS - Natural human voice (free, self-hosted)
# Run: docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:latest
KOKORO_TTS_URL=http://localhost:8880
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0

# Faster-Whisper STT - Speech to text (free, self-hosted)
# Run: docker run -p 8765:8765 ghcr.io/collabora/whisperlive-cpu:latest
WHISPER_STT_URL=ws://localhost:8765
WHISPER_MODEL=base
WHISPER_LANGUAGE=auto

# ============================================
# TWILIO (optional - for phone calls)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=http://localhost:3000/api/voice/twilio/incoming

# ============================================
# DATABASE (SQLite - zero cost, no setup)
# ============================================
DATABASE_URL=file:./voiceforge.db
