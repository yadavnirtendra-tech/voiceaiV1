# ============================================
# OpenCalendar - Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development
API_BASE_URL=https://autocalender-production.up.railway.app
FRONTEND_URL=https://opencalender.site

# Database (Supabase PostgreSQL)
# IMPORTANT: If your password contains special characters like [ ] @, they MUST be URL-encoded!
# Example: [ -> %5B, ] -> %5D, @ -> %40
# Example URL: postgresql://postgres:%5Bpassword%40here%5D@db.ref.supabase.co:5432/postgres
DATABASE_URL=your-supabase-connection-string-here
# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Encryption (AES-256-GCM for token storage)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://opencalender.site/api/auth/google/callback

# Microsoft OAuth 2.0 (Azure AD)
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://opencalender.site/api/auth/microsoft/callback

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-verification-secret
GOOGLE_WEBHOOK_URL=https://opencalender.site/api/webhook/google
MICROSOFT_WEBHOOK_URL=https://opencalender.site/api/webhook/microsoft

# Sync Engine
SYNC_ORIGIN_TAG=calendarsync-ai-system
SHADOW_BLOCK_TITLE=Reserved (CalendarSync)
MAX_SYNC_RETRIES=3
SYNC_RETRY_DELAY_MS=1000
